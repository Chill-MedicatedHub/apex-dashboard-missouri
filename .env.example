# ── Chill Medicated · Missouri — scraper config ──────────────────────────────
# Copy this file to ".env" and fill in the values for your MISSOURI Apex account.
#   macOS/Linux:  cp .env.example .env
#   Windows:      copy .env.example .env
# Never commit .env to git — it holds a live session cookie.

# REQUIRED — your Missouri Apex session cookie (the whole Cookie: value).
# Re-grab this every few weeks when it expires. See README for the 30-second steps.
APEX_COOKIE=""

# REQUIRED for a different account — these identify the Missouri account/company.
# Find them in the report request payload (same Network tab where you got the cookie).
# If you leave them unset, the script falls back to the Massachusetts defaults,
# which will pull the WRONG account — so set these for Missouri.
APEX_USER_ID=""
APEX_COMPANY_ID=""

# Brand filter. Missouri may use a different brand id than Massachusetts even for
# the same brand name. Set the Missouri brand id here.
# Leave APEX_BRAND_ID blank to use the MA default (2500) — usually NOT what you want.
APEX_BRAND_ID=""
APEX_BRAND_NAME="Chill Medicated"

# OPTIONAL — date range.
# Fixed start date (preferred), e.g. 2025-05-01. Leave blank to use a rolling window.
APEX_FROM_DATE=""
# Rolling window length in days, used only when APEX_FROM_DATE is blank.
APEX_DAYS_BACK="90"

# OPTIONAL — max rows to pull per request.
APEX_ROW_LIMIT="5000"
